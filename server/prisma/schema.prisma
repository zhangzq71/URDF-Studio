// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model URDFStudioAsset {
  // Use String @id to match our UUIDs
  id            String   @id
  name          String
  
  // Optional fields with defaults
  author        String?  @default("")
  description   String?  @default("")
  thumbnail     String?  @default("")
  category      String   @default("Full Robots")
  
  stars         Int      @default(0)
  downloads     Int      @default(0)
  
  // Store arrays as simple JSON strings in SQLite since it doesn't support string arrays natively
  // We will parse/stringify manually in service layer
  tags          String   @default("[]") 
  
  lastUpdated   DateTime @default(now())

  // File paths
  urdfPath      String
  urdfFile      String?
  previewVideo  String?

  // Chinese translations (Optional)
  name_zh       String?
  description_zh String?
  tags_zh       String?  @default("[]")
  author_zh     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

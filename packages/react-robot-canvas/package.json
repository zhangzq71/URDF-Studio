{
  "name": "@urdf-studio/react-robot-canvas",
  "version": "0.1.0",
  "description": "Reusable React 3D robot canvas with URDF and MJCF import support.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/lib/index.d.ts",
  "style": "./dist/style.css",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/lib/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "keywords": [
    "react",
    "three",
    "robotics",
    "urdf",
    "mjcf",
    "r3f",
    "canvas"
  ],
  "peerDependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.181.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ../../node_modules/vite/bin/vite.js build -c ./vite.config.ts && node ../../node_modules/typescript/bin/tsc -p ./tsconfig.types.json && node ../../scripts/rewrite_dts_aliases.mjs ./dist/types && node ./scripts/postbuild.mjs",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  }
}
